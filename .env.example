# AI Alpha Squad — copy to .env (never commit .env)
# See .agents/infrastructure-prerequisites.md for setup steps.

# --- Squad (required for all jobs) ---
GITHUB_OWNER=eduardocerqueira
SQUAD_WORK_QUEUE_REPO=ai-alpha-squad
# Director GitHub username — only this login may approve on Issues (see docs/director-gate.md)
SQUAD_DIRECTOR_LOGIN=eduardocerqueira
# Optional: GitHub login used by WhatsApp Worker PAT when adding director-approved (defaults to Director)
# SQUAD_WHATSAPP_APPROVAL_LOGIN=
# GitHub CLI / API (issues, PRs, releases) — gh auth login OR:
# GITHUB_TOKEN=

# --- Director WhatsApp (optional — pipeline uses GitHub Issues for approvals) ---
# Set SQUAD_WHATSAPP_NOTIFY=0 to skip; unset = auto (send only when all three are set)
# SQUAD_WHATSAPP_NOTIFY=auto
WHATSAPP_API_PROVIDER=meta
WHATSAPP_DIRECTOR_PHONE=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Meta App settings → Basic → App secret (validates X-Hub-Signature-256 on POST)
WHATSAPP_APP_SECRET=
# Issue to attach inbound Director replies until KV correlation exists
WHATSAPP_DEFAULT_ISSUE_NUMBER=1
# Kapso alternative:
# KAPSO_API_KEY=
# KAPSO_API_BASE_URL=

# --- Cloudflare (Workers, D1, R2, DNS — when tech spec requires) ---
# Use the Cloudflare account dedicated to ai-alpha-squad — NOT the Bmhp org account (separate project).
#
# Account API Token (cfat_…): https://dash.cloudflare.com/?to=/:account/api-tokens
# Must include ZONE permissions for SQUAD_DOMAIN (account-wide "all permissions" is not enough):
#   Zone → DNS → Edit
#   Zone → Email Routing Rules → Edit
#   Account → Email Routing Addresses → Edit
#   Account → Email Sending → Edit
#   Account → Workers Scripts → Edit (deploy)
# Verify: ./scripts/verify-cloudflare-token.sh
CLOUDFLARE_API_TOKEN=
# Optional: use a second token for wrangler deploy if CLOUDFLARE_API_TOKEN is zone-only (DNS/email)
# CLOUDFLARE_DEPLOY_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Optional safety: deploy script aborts if account name does not match (see deploy-whatsapp-webhook.sh)
# CLOUDFLARE_EXPECT_ACCOUNT_NAME=
# Squad domain (Cloudflare Registrar on this account):
SQUAD_DOMAIN=aialphasquad.com
WHATSAPP_WEBHOOK_HOSTNAME=whatsapp-webhook.aialphasquad.com
# CLOUDFLARE_ZONE_ID=  # optional; from zone overview if needed

# --- Squad website (aialphasquad.com landing + contact form) ---
CONTACT_TO_EMAIL=contact@aialphasquad.com
CONTACT_FROM_EMAIL=noreply@aialphasquad.com
# Inbox that receives contact form + mail to contact@ (Cloudflare Email Routing forward target)
CONTACT_EMAIL_FORWARD_TO=
# Optional: narrow token with Account → Email Sending only (defaults to CLOUDFLARE_API_TOKEN)
# CLOUDFLARE_EMAIL_SEND_TOKEN=
# Turnstile: https://dash.cloudflare.com/?to=/:account/turnstile
# Test keys (always pass): site 1x00000000000000000000AA / secret 1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Squad AI provider (orchestrator dispatch) ---
# copilot = GitHub Copilot coding agent (default, Phase 1)
# huggingface = HF Inference Providers via router API (issue comments + optional CI run)
# SQUAD_AI_PROVIDER=huggingface
# Squad coding agent runtime for developer/devops (no Copilot): actions | copilot
# SQUAD_CODE_RUNTIME=actions
# Default HF model when an agent doc has no ## AI Model override:
# SQUAD_HF_DEFAULT_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct
# SQUAD_HF_RUN_IN_CI=1
# SQUAD_HF_ROUTER_URL=https://router.huggingface.co/v1/chat/completions
# HF router provider policy suffix on every request (default cheapest — lowest price per token)
# SQUAD_HF_PROVIDER_POLICY=cheapest
# Alternatives: fastest | preferred | none (use model id as-is, e.g. org/model:groq)

# --- Hugging Face (models, Jobs, datasets — when spec requires) ---
HF_TOKEN=

# --- VS Code extension job (Marketplace + Open VSX) ---
VSCE_PAT=
OPENVSX_PAT=
# Publisher ID(s) — not secret, but required for publish:
# VSCE_PUBLISHER=
# OPENVSX_NAMESPACE=

# --- Apple App Store job (when spec requires) ---
# App Store Connect API key (path or base64 — prefer local path outside repo):
# APP_STORE_CONNECT_API_KEY_PATH=
# APP_STORE_CONNECT_KEY_ID=
# APP_STORE_CONNECT_ISSUER_ID=
# APPLE_TEAM_ID=
# Fastlane / signing (usually in target repo, not committed):
# MATCH_PASSWORD=
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=

# --- Legacy modernization (per target repo — set in that repo’s .env) ---
# SONAR_TOKEN=
# CODECOV_TOKEN=

# --- Cursor / local agent runtime (optional) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# CURSOR_API_KEY=

# Autonomous planning: post BA/tech spec from job pack when Copilot cannot (issue-first)
# SQUAD_AUTONOMOUS_PLANNING=1
# SQUAD_MAX_PLANNING_NUDGES=2
