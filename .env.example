# AI Alpha Squad — copy to .env (never commit .env)
# See .agents/infrastructure-prerequisites.md for setup steps.

# --- Squad (required for all jobs) ---
GITHUB_OWNER=eduardocerqueira
SQUAD_WORK_QUEUE_REPO=ai-alpha-squad
# GitHub CLI / API (issues, PRs, releases) — gh auth login OR:
# GITHUB_TOKEN=

# --- Director WhatsApp (Business Owner + Release Manager) ---
WHATSAPP_API_PROVIDER=meta
WHATSAPP_DIRECTOR_PHONE=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
# Meta App settings → Basic → App secret (validates X-Hub-Signature-256 on POST)
WHATSAPP_APP_SECRET=
# Issue to attach inbound Director replies until KV correlation exists
WHATSAPP_DEFAULT_ISSUE_NUMBER=1
# Kapso alternative:
# KAPSO_API_KEY=
# KAPSO_API_BASE_URL=

# --- Cloudflare (Workers, D1, R2, DNS — when tech spec requires) ---
# Use the Cloudflare account dedicated to ai-alpha-squad — NOT the Bmhp org account (separate project).
# API token: Edit Cloudflare Workers (+ Zone if using a custom webhook hostname).
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
# Optional safety: deploy script aborts if account name does not match (see deploy-whatsapp-webhook.sh)
# CLOUDFLARE_EXPECT_ACCOUNT_NAME=
# Squad domain (Cloudflare Registrar on this account):
SQUAD_DOMAIN=aialphasquad.com
WHATSAPP_WEBHOOK_HOSTNAME=whatsapp-webhook.aialphasquad.com
# CLOUDFLARE_ZONE_ID=  # optional; from zone overview if needed

# --- Hugging Face (models, Jobs, datasets — when spec requires) ---
HF_TOKEN=

# --- VS Code extension job (Marketplace + Open VSX) ---
VSCE_PAT=
OPENVSX_PAT=
# Publisher ID(s) — not secret, but required for publish:
# VSCE_PUBLISHER=
# OPENVSX_NAMESPACE=

# --- Apple App Store job (when spec requires) ---
# App Store Connect API key (path or base64 — prefer local path outside repo):
# APP_STORE_CONNECT_API_KEY_PATH=
# APP_STORE_CONNECT_KEY_ID=
# APP_STORE_CONNECT_ISSUER_ID=
# APPLE_TEAM_ID=
# Fastlane / signing (usually in target repo, not committed):
# MATCH_PASSWORD=
# FASTLANE_APPLE_APPLICATION_SPECIFIC_PASSWORD=

# --- Legacy modernization (per target repo — set in that repo’s .env) ---
# SONAR_TOKEN=
# CODECOV_TOKEN=

# --- Cursor / local agent runtime (optional) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# CURSOR_API_KEY=
