{
  "name": "ai-alpha-squad-landing",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "workers_dev": true,
  "observability": { "enabled": true },
  "send_email": [{ "name": "EMAIL" }],
  "vars": {
    "CONTACT_TO_EMAIL": "contact@aialphasquad.com",
    "CONTACT_FROM_EMAIL": "noreply@aialphasquad.com",
    "CONTACT_DELIVERY_EMAIL": "",
    "CLOUDFLARE_ACCOUNT_ID": "",
    "TURNSTILE_SITE_KEY": "0x4AAAAAADbgiy2bBXlEoAKP",
    // Director dashboard allowlist (comma-separated). AUTH_SECRET is a secret:
    //   cd site && wrangler secret put AUTH_SECRET
    "DIRECTOR_ALLOWED_EMAILS": "eduardomcerqueira@gmail.com"
  },
  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/api/*"],
    "not_found_handling": "404-page",
    "html_handling": "auto-trailing-slash"
  }
}
